(echo # Ignore password and secret files & echo password.txt & echo secret.txt & echo api_key.txt & echo. & echo # Ignore environment variables & echo .env & echo .env.local & echo. & echo # Ignore temporary files & echo temp.txt & echo. & echo # Ignore log files & echo *.log & echo. & echo # Ignore cache & echo cache/ & echo. & echo # Ignore OS files & echo .DS_Store & echo Thumbs.db & echo. & echo # Ignore node_modules & echo node_modules/ & echo. & echo # Ignore IDE files & echo .vscode/ & echo .idea/) > .gitignore